<?xml version="1.0"?>
<ruleset name="pra-theme">
    <description>
        Security and i18n correctness: output escaping, input sanitization,
        nonces, prepared SQL, gettext with the right text domain. Formatting
        sniffs are intentionally not enabled — substance over whitespace.
    </description>

    <file>.</file>
    <exclude-pattern>tests/*</exclude-pattern>
    <exclude-pattern>assets/*</exclude-pattern>
    <exclude-pattern>vendor/*</exclude-pattern>

    <arg value="sp"/>
    <arg name="extensions" value="php"/>
    <arg name="parallel" value="8"/>

    <config name="minimum_wp_version" value="6.0"/>

    <!-- Security: output escaping, input sanitization, nonces, SQL -->
    <rule ref="WordPress.Security.EscapeOutput"/>
    <rule ref="WordPress.Security.ValidatedSanitizedInput"/>
    <rule ref="WordPress.Security.NonceVerification"/>
    <rule ref="WordPress.DB.PreparedSQL"/>
    <rule ref="WordPress.DB.PreparedSQLPlaceholders"/>

    <!-- i18n: correct text domain and gettext usage -->
    <rule ref="WordPress.WP.I18n"/>
    <config name="text_domain" value="pra-theme"/>

    <!-- No bare eval/create_function/extract -->
    <rule ref="Generic.PHP.ForbiddenFunctions">
        <properties>
            <property name="forbiddenFunctions" type="array">
                <element key="eval" value="null"/>
                <element key="create_function" value="null"/>
                <element key="extract" value="null"/>
            </property>
        </properties>
    </rule>
</ruleset>
